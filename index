            <div class="form-group">
              <label for="name" class="form-label">Nombre completo *</label>
              <input type="text" id="name" name="name" class="form-input" placeholder="Lic. Juan Pérez" required />
              <span class="form-error" id="nameError">Por favor ingrese su nombre.</span>
            </div>

            <div class="form-group">
              <label for="company" class="form-label">Empresa</label>
              <input type="text" id="company" name="company" class="form-input" placeholder="Nombre de su empresa" />
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="email" class="form-label">Correo electrónico *</label>
                <input type="email" id="email" name="email" class="form-input" placeholder="correo@empresa.com" required />
                <span class="form-error" id="emailError">Ingrese un correo válido.</span>
              </div>
              <div class="form-group">
                <label for="phone" class="form-label">Teléfono</label>
                <input type="tel" id="phone" name="phone" class="form-input" placeholder="+52 55 0000 0000" />
              </div>
            </div>

            <div class="form-group">
              <label for="service" class="form-label">Área de interés *</label>
              <select id="service" name="service" class="form-input form-select" required>
                <option value="">Seleccione un servicio…</option>
                <option value="corporativo">Derecho Corporativo</option>
                <option value="mna">Fusiones y Adquisiciones</option>
                <option value="contratos">Contratos Comerciales</option>
                <option value="compliance">Cumplimiento Normativo</option>
                <option value="litigio">Litigio Mercantil</option>
                <option value="asesoria">Asesoría Empresarial</option>
                <option value="otro">Otro</option>
              </select>
              <span class="form-error" id="serviceError">Seleccione un área.</span>
            </div>

            <div class="form-group">
              <label for="message" class="form-label">Descripción del asunto *</label>
              <textarea id="message" name="message" class="form-input form-textarea" rows="4" placeholder="Describa brevemente su situación legal…" required></textarea>
              <span class="form-error" id="messageError">Por favor describa su asunto.</span>
            </div>

            <div class="form-group form-group--checkbox">
              <input type="checkbox" id="privacy" name="privacy" class="form-checkbox" required />
              <label for="privacy" class="form-label form-label--checkbox">
                He leído y acepto el <a href="#" class="form-link">aviso de privacidad</a> y el tratamiento de mis datos personales. *
              </label>
              <span class="form-error" id="privacyError">Debe aceptar el aviso de privacidad.</span>
            </div>

            <button type="submit" class="btn btn--primary btn--full">Enviar mensaje</button>

            <!-- Mensaje de éxito (oculto hasta envío) -->
            <div class="form-success" id="formSuccess" hidden>
              <span>✓</span> Gracias por contactarnos. Le responderemos en menos de 24 horas hábiles.
            </div>
          </form>
